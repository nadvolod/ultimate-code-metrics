FROM maven:3.9-eclipse-temurin-11 AS build
WORKDIR /app
COPY pom.xml .
COPY ../pom.xml ../pom.xml
RUN mvn dependency:go-offline -pl . -q || true
COPY src ./src
RUN mvn package -DskipTests -pl . -q

FROM eclipse-temurin:11-jre-alpine
WORKDIR /app
COPY --from=build /app/target/temporal-review-*.jar app.jar
ENTRYPOINT ["java", "-cp", "app.jar", "com.utm.temporal.LearningWorkerApp"]
CMD ["owner/repo"]
